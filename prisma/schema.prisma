generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  VICTIM
  VOLUNTEER
  NGO
}
enum SosType {
  FOOD
  MEDICAL
  RESCUE
}
enum SosStatus {
  ACTIVE
  ASSIGNED
  RESOLVED
}
enum SosSource {
  INTERNET
  BLUETOOTH
  QUEUED
  VOICE
}
enum TaskStatus {
  ACCEPTED
  ENROUTE
  COMPLETED
}

model User {
  id        String          @id @default(cuid())
  name      String
  phone     String
  email     String          @unique
  role      Role
  lat       Float?
  lng       Float?
  createdAt DateTime        @default(now())
  sosAlerts SosAlert[]
  tasks     Task[]
  ratings   VolunteerRating[]
}

model SosAlert {
  id           String    @id @default(cuid())
  userId       String
  type         SosType
  description  String
  lat          Float
  lng          Float
  status       SosStatus @default(ACTIVE)
  source       SosSource @default(INTERNET)
  relayCount   Int       @default(0)
  isVoiceSOS   Boolean   @default(false)
  aiSuggestion String?
  photoUrl     String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id])
  tasks        Task[]
}

model Task {
  id          String     @id @default(cuid())
  sosId       String
  volunteerId String
  status      TaskStatus @default(ACCEPTED)
  acceptedAt  DateTime   @default(now())
  completedAt DateTime?
  sos         SosAlert   @relation(fields: [sosId], references: [id])
  volunteer   User       @relation(fields: [volunteerId], references: [id])
}

model VolunteerRating {
  id           String   @id @default(cuid())
  volunteerId  String
  rating       Int
  review       String?
  createdAt    DateTime @default(now())
  volunteer    User     @relation(fields: [volunteerId], references: [id])
}

model Resource {
  id        String   @id @default(cuid())
  name      String
  category  String   // FOOD, MEDICAL, RESCUE
  quantity  Int      @default(0)
  unit      String   // kg, units, liters, etc.
  location  String   // depot/camp name
  ngoId     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model ChatMessage {
  id          String   @id @default(cuid())
  sosId       String
  senderId    String
  senderName  String
  senderRole  String
  message     String
  messageType String   @default("TEXT")
  createdAt   DateTime @default(now())
}

// ─── Feature Suite ───────────────────────────────────

model MapResource {
  id         String   @id @default(cuid())
  type       String   // WATER | FOOD | MEDICAL | SHELTER | POWER
  lat        Float
  lng        Float
  capacity   Int      @default(0)
  notes      String?
  reporterId String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model MissingPerson {
  id          String   @id @default(cuid())
  name        String
  age         Int?
  lastSeen    String
  description String
  photoUrl    String?
  status      String   @default("MISSING")  // MISSING | FOUND
  reporterId  String
  foundBy     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DisasterAlert {
  id         String   @id @default(cuid())
  message    String
  severity   String   @default("MEDIUM")  // LOW | MEDIUM | HIGH | CRITICAL
  source     String   @default("NGO")
  area       String?
  isActive   Boolean  @default(true)
  createdBy  String
  createdAt  DateTime @default(now())
}

model SosEvent {
  id        String   @id @default(cuid())
  sosId     String
  event     String   // SOS_CREATED | PACKET_RELAYED | VOLUNTEER_DETECTED | MISSION_ACCEPTED | STATUS_UPDATE | RESCUE_COMPLETED
  actor     String?  // userId or 'system'
  actorName String?
  metadata  String?  // JSON stringified extra data
  createdAt DateTime @default(now())
}

model BroadcastMessage {
  id        String   @id @default(cuid())
  message   String
  target    String
  userIds   String?  // JSON stringified array of specific user IDs if targeted globally
  createdAt DateTime @default(now())
}
